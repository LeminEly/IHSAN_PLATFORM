# 🌐 IHSAN Platform Configuration

# ───── Server ─────
PORT=3000
NODE_ENV=production
CLIENT_URL=https://ihsan-platform.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# ───── Database (Supabase) ─────
# Ensure ?sslmode=require is appended to the connection string
DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres?sslmode=require

# ───── Authentication ─────
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d

# ───── Cloudinary (Images) ─────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ───── Chinguisoft SMS ─────
# Dedicated for Mauritanian market
CHINGUIS_VALIDATION_KEY=your_chinguisoft_key
CHINGUIS_VALIDATION_TOKEN=your_chinguisoft_token
SMS_APP_NAME=IHSAN

# ───── Notification ─────
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key

# ───── Blockchain (Polygon Amoy) ─────
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
BLOCKCHAIN_PRIVATE_KEY=your_wallet_private_key
CONTRACT_ADDRESS=0x...
EXPLORER_BASE_URL=https://amoy.polygonscan.com/tx/
