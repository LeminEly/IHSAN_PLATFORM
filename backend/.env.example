# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────────
# Set DATABASE_URL for Supabase/Render (Transaction mode for Supabase: port 6543)
DATABASE_URL=postgresql://user:password@host:6543/postgres?sslmode=require

# OR set individual variables for local/standard DB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ihsan_db
DB_USER=ihsan_user
DB_PASSWORD=ihsan_password

# ─── JWT ─────────────────────────────────────────────────────────────────────────
JWT_SECRET=your-very-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-very-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRE=30d

# ─── SMS (Chinguisoft) ──────────────────────────────────────────────────────────
# Get your keys at https://chinguisoft.com/
CHINGUIS_VALIDATION_KEY=your_validation_key
CHINGUIS_VALIDATION_TOKEN=your_validation_token
SMS_APP_NAME=IHSAN

# ─── Cloudinary (Photos/Media) ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=IHSAN_PLATFORM
CLOUDINARY_API_KEY=817692829597455
CLOUDINARY_API_SECRET=uHXzY5pJOS0jhTInC_UW8sohe0o

# ─── Blockchain (Polygon - OPTIONAL) ─────────────────────────────────────────────
# Leave empty to disable blockchain features
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_PRIVATE_KEY=your_private_key_without_0x
POLYGON_CONTRACT_ADDRESS=0xYourContractAddress
POLYGON_EXPLORER_URL=https://polygonscan.com/tx/

# ─── Push Notifications (OneSignal) ──────────────────────────────────────────────
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_rest_api_key
